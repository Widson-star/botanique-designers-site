# Frontend (Vite) — exposed to the browser, non-secret values only.
# Copy this file to .env and fill in real values. Do NOT commit .env.
#
# The site is designed to run as a STATIC frontend with NO backend. With nothing
# set below, every commercial path still works: WhatsApp lead templates, the
# quote wizard, project/service CTAs, manual payment instructions, and a contact
# form that falls back to WhatsApp / call / email. The variables below are
# OPTIONAL enhancements.

# OPTIONAL. Base URL of the separately-hosted Express API (server/index.js),
# e.g. https://api.botaniquedesigners.com
#   - UNSET (recommended default): contact form posts nothing and shows the
#     WhatsApp/call/email fallback; Ask Botanique replies with a WhatsApp prompt.
#   - SET: contact form emails via the server and Ask Botanique uses Groq chat.
# Never point this at http://localhost in production.
VITE_BACKEND_URL=

# OPTIONAL. Set to "true" ONLY when PRODUCTION Daraja M-Pesa credentials are live
# on the server. When unset/false (default), the consultancy modal shows manual
# Till/Bank payment instructions + WhatsApp confirmation (no in-app STK prompt).
VITE_MPESA_STK_ENABLED=false

# OPTIONAL for the private /admin prototype becoming real operational software.
# These values are frontend-safe only when Supabase Row Level Security is enabled
# on every admin table. Use a Botanique-only Supabase project, not Apicora.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Backend secrets live in server/.env (gitignored) — never in this file and never
# exposed to the browser. Only needed if you actually deploy server/index.js:
#   PORT=5001
#   CORS_ORIGINS=https://www.botaniquedesigners.com,https://botaniquedesigners.com
#   GROQ_API_KEY=            # enables the Ask Botanique chat endpoint
#   EMAIL_USER=              # Gmail address for the contact form
#   EMAIL_PASS=              # Gmail App Password (Account > Security > App Passwords)
#   MPESA_CONSUMER_KEY=      # M-Pesa Daraja — sandbox unless production-approved
#   MPESA_CONSUMER_SECRET=
#   MPESA_SHORTCODE=
#   MPESA_PASSKEY=
#   CALLBACK_URL=
#
# Never expose SUPABASE_SERVICE_ROLE_KEY in Vite/frontend code.
